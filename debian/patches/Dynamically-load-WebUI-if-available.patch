+// <Debian-specific>
+// We cannot embed upstream's pre-built UI, but users may download it at
+// install-time, and we can load it at run-time. To this end, we implement
+// *_local versions of asset-relevant functions.
+
+// Copied from tools/ui/embed.cpp
+static const char * mime_from_ext_local(const std::string & name) {
+    const auto ext = name.rfind('.');
+    if (ext == std::string::npos) return "application/octet-stream";
+    const std::string e = name.substr(ext + 1);
+    if (e == "html")        return "text/html; charset=utf-8";
+    if (e == "css")         return "text/css";
+    if (e == "js")          return "application/javascript";
+    if (e == "json")        return "application/json";
+    if (e == "webmanifest") return "application/manifest+json";
+    if (e == "svg")         return "image/svg+xml";
+    if (e == "png")         return "image/png";
+    if (e == "jpg" ||
+        e == "jpeg")        return "image/jpeg";
+    if (e == "ico")         return "image/x-icon";
+    if (e == "woff")        return "font/woff";
+    if (e == "woff2")       return "font/woff2";
+    return "application/octet-stream";
+}
+
+// Copied from tools/ui/embed.cpp and modified to return a string, as this is
+// what eventually would happen in ui.h for the embedded asset version
+static std::string fnv_hash_local(const uint8_t * data, size_t len) {
+    const uint64_t fnv_prime = 0x100000001b3ULL;
+    uint64_t hash = 0xcbf29ce484222325ULL;
+
+    for (size_t i = 0; i < len; ++i) {
+        hash ^= data[i];
+        hash *= fnv_prime;
+    }
+
+    char buf[32];
+    snprintf(buf, sizeof(buf), "\"0x%016" PRIx64 "\"", hash);
+    return buf;
+}
+
+// Indicates which UI the user configured
+static std::optional<std::filesystem::path> ui_path() {
+    static const auto result = []() -> std::optional<std::filesystem::path> {
+        std::error_code ec;
+        const std::filesystem::path default_ui_path = "/usr/share/llama.cpp/llama-server/default-ui";
+        if (std::filesystem::is_symlink(default_ui_path, ec) && !ec) {
+            return std::filesystem::read_symlink(default_ui_path, ec);
+        }
+        return std::nullopt;
+    }();
+    return result;
+}
+
+// Construct a vector of assets, loading them from the file system, to emulate
+// the embedded assets version
+static const std::vector<llama_ui_asset> & llama_ui_get_assets_local() {
+    static const auto table = []() {
+        std::vector<llama_ui_asset> result;
+        std::error_code ec;
+
+        // Do we have an UI configured?
+        if (!ui_path()) {
+            return result;
+        }
+        std::filesystem::path ui_dir = *ui_path();
+
+        // Is the UI configured a downloaded one?
+        std::string prefix = "/var/lib/llama.cpp/llama-server";
+        if (ui_dir.string().size() < prefix.size() || ui_dir.string().compare(0, prefix.size(), prefix) != 0) {
+            return result;
+        }
+
+        // embed.cpp sorts names out of necessity, we do it out of consistency
+        std::vector<std::string> names;
+        for (std::filesystem::recursive_directory_iterator it(ui_dir, ec), end; !ec && it != end; it.increment(ec)) {
+            // Need to skip the _app subdirectory
+            if (it->is_regular_file()) {
+                names.push_back(it->path().lexically_relative(ui_dir));
+            }
+        }
+        std::sort(names.begin(), names.end());
+
+        for (const std::string & name : names) {
+            std::filesystem::path asset_path = ui_dir / name;
+            std::ifstream fil(asset_path, std::ios::binary | std::ios::ate);
+            if (!fil) {
+                fprintf(stderr, "Debian llama-serve: cannot open %s\n", asset_path.c_str());
+                exit(1);
+            }
+
+            const std::streamsize siz = fil.tellg();
+            if (siz < 0) {
+                fprintf(stderr, "Debian llama-serve: cannot read size of %s\n", asset_path.c_str());
+                exit(1);
+            }
+
+            auto * buf = new uint8_t[static_cast<size_t>(siz)];
+            fil.seekg(0);
+            if (siz > 0 && !fil.read(reinterpret_cast<char *>(buf), siz)) {
+                fprintf(stderr, "Debian llama-serve: cannot read %s\n", asset_path.c_str());
+                exit(1);
+            }
+
+            llama_ui_asset a;
+            a.name = name;
+            a.data = buf;
+            a.size = static_cast<size_t>(siz);
+            a.etag = fnv_hash_local(buf, static_cast<size_t>(siz));
+            a.type = mime_from_ext_local(name);
+            result.push_back(std::move(a));
+        }
+        return result;
+    }();
+    return table;
+}
+
+static const llama_ui_asset * llama_ui_find_asset_local(const std::string & name) {
+    for (const llama_ui_asset & a : llama_ui_get_assets_local()) {
+        if (a.name == name) {
+            return &a;
+        }
+    }
+    return nullptr;
+}
