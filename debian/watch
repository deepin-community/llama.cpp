Matching-Pattern: (?:.*?/)?b?(\d[\d.]*)\.tar\.gz
Dversionmangle: auto
Filenamemangle: s%(?:.*?)?b?(\d[\d.]*)\.tar\.gz%llama.cpp-$1.tar.gz%
Repacksuffix: +dfsg
